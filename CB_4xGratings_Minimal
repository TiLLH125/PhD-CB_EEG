function CB_4xGratings_Minimal
% Minimal CB demo: SPACE to start, then fixed S1-ISI-S2 trials.

close all;
try ListenChar(0); catch, end
try KbQueueRelease(-1); catch, end

if exist('sca','file') == 2
    sca;
elseif exist('Screen','file') == 2
    Screen('CloseAll');
end

cfg = struct();
cfg.screenNumber = max(Screen('Screens'));
cfg.kbDev = -1;
cfg.keys.escape = KbName('ESCAPE');
cfg.keys.space = KbName('space');

cfg.nTrials = 10;
cfg.stimSec = 0.5;
cfg.isiSec = 0.1;
cfg.itiSec = 0.5;
cfg.fixJitterRangeSec = [0.5 0.8];

cfg.stim.squareSizePx = 220;
cfg.stim.spacingPx = 150;
cfg.stim.cyclesPerStim = 10;
cfg.stim.contrast = 0.8;
cfg.stim.backgroundGrey = 0.5;
cfg.stim.gaborSigmaFrac = 0.40;
cfg.stim.allowedOri = 0:22.5:157.5;

cfg.fix.sizePx = 14;
cfg.fix.lineWidthPx = 3;

Screen('Preference','VisualDebugLevel', 1);
Screen('Preference','SkipSyncTests', 1);

KbName('UnifyKeyNames');
PsychDefaultSetup(2);

bg = cfg.stim.backgroundGrey;
black = 0;
window = [];

try
    [window, windowRect] = PsychImaging('OpenWindow', cfg.screenNumber, bg);
    cleanupObj = onCleanup(@() cleanup(window, cfg));

    Screen('BlendFunction', window, 'GL_SRC_ALPHA', 'GL_ONE_MINUS_SRC_ALPHA');
    Screen('TextFont', window, 'Arial');
    Screen('TextSize', window, 40);

    ifi = Screen('GetFlipInterval', window);
    [xCentre, yCentre] = RectCenter(windowRect);

    stimFrames = max(1, round(cfg.stimSec / ifi));
    isiFrames = max(1, round(cfg.isiSec / ifi));
    itiFrames = max(1, round(cfg.itiSec / ifi));
    fixJitterFrames = round(cfg.fixJitterRangeSec / ifi);
    missedFlipFramesTotal = 0;
    missedFlipEventsTotal = 0;

    baseRect = [0 0 cfg.stim.squareSizePx cfg.stim.squareSizePx];
    xPos = [xCentre - cfg.stim.spacingPx, xCentre + cfg.stim.spacingPx, ...
            xCentre - cfg.stim.spacingPx, xCentre + cfg.stim.spacingPx];
    yPos = [yCentre - cfg.stim.spacingPx, yCentre - cfg.stim.spacingPx, ...
            yCentre + cfg.stim.spacingPx, yCentre + cfg.stim.spacingPx];
    allRects = nan(4,4);
    for i = 1:4
        allRects(i,:) = CenterRectOnPoint(baseRect, xPos(i), yPos(i));
    end

    gratingTex = makeGratingTexture(window, cfg.stim.squareSizePx, ...
        cfg.stim.cyclesPerStim, cfg.stim.contrast, bg, cfg.stim.gaborSigmaFrac);
    fixationCoords = [-cfg.fix.sizePx cfg.fix.sizePx 0 0; 0 0 -cfg.fix.sizePx cfg.fix.sizePx];

    try KbQueueRelease(cfg.kbDev); catch, end
    KbQueueCreate(cfg.kbDev);
    KbQueueStart(cfg.kbDev);
    KbQueueFlush(cfg.kbDev);

    drawStartScreen(window, windowRect, black, bg);
    Screen('Flip', window);
    waitForKeyQueue([cfg.keys.space], cfg.keys.escape, Inf, cfg);

    for t = 1:cfg.nTrials
        checkAbort(cfg);

        oriS1 = cfg.stim.allowedOri(randperm(numel(cfg.stim.allowedOri), 4))';
        oriS2 = oriS1;

        jitterFrames = randi([fixJitterFrames(1), fixJitterFrames(2)], 1, 1);
        drawFixationOnly(window, bg, fixationCoords, cfg.fix.lineWidthPx, black, xCentre, yCentre);
        tFix = Screen('Flip', window);
        holdForSecondsWithAbort(tFix + jitterFrames * ifi, cfg);

        drawGratings(window, gratingTex, allRects, oriS1, bg);
        drawFixation(window, fixationCoords, cfg.fix.lineWidthPx, black, xCentre, yCentre);
        tS1 = Screen('Flip', window);
        [missedFlipFramesTotal, missedFlipEventsTotal] = addMissedFlips( ...
            missedFlipFramesTotal, missedFlipEventsTotal, tFix + jitterFrames * ifi, tS1, ifi);
        holdForSecondsWithAbort(tS1 + stimFrames * ifi, cfg);

        drawFixationOnly(window, bg, fixationCoords, cfg.fix.lineWidthPx, black, xCentre, yCentre);
        tISI = Screen('Flip', window);
        [missedFlipFramesTotal, missedFlipEventsTotal] = addMissedFlips( ...
            missedFlipFramesTotal, missedFlipEventsTotal, tS1 + stimFrames * ifi, tISI, ifi);
        holdForSecondsWithAbort(tISI + isiFrames * ifi, cfg);

        drawGratings(window, gratingTex, allRects, oriS2, bg);
        drawFixation(window, fixationCoords, cfg.fix.lineWidthPx, black, xCentre, yCentre);
        tS2 = Screen('Flip', window);
        [missedFlipFramesTotal, missedFlipEventsTotal] = addMissedFlips( ...
            missedFlipFramesTotal, missedFlipEventsTotal, tISI + isiFrames * ifi, tS2, ifi);
        holdForSecondsWithAbort(tS2 + stimFrames * ifi, cfg);

        drawFixationOnly(window, bg, fixationCoords, cfg.fix.lineWidthPx, black, xCentre, yCentre);
        tITI = Screen('Flip', window);
        [missedFlipFramesTotal, missedFlipEventsTotal] = addMissedFlips( ...
            missedFlipFramesTotal, missedFlipEventsTotal, tS2 + stimFrames * ifi, tITI, ifi);
        holdForSecondsWithAbort(tITI + itiFrames * ifi, cfg);
    end

    Screen('FillRect', window, bg);
    DrawFormattedText(window, 'Finished', 'center', 'center', black);
    tDone = Screen('Flip', window);
    holdForSecondsWithAbort(tDone + 0.75, cfg);
    fprintf('\n--- Missed Flips Summary ---\n');
    fprintf('Total missed-flip events: %d\n', missedFlipEventsTotal);
    fprintf('Total missed frames: %d\n', missedFlipFramesTotal);
    fprintf('----------------------------\n\n');

    %#ok<NASGU>
    clear cleanupObj
catch ME
    try cleanup(window, cfg); catch, end
    rethrow(ME);
end
end

function drawStartScreen(window, windowRect, black, bg)
Screen('FillRect', window, bg);
DrawFormattedText(window, 'Change Blindness Demo', 'center', windowRect(4) * 0.38, black);
DrawFormattedText(window, 'Press SPACEBAR to start', 'center', windowRect(4) * 0.55, black);
DrawFormattedText(window, 'Press ESC to quit', 'center', windowRect(4) * 0.62, black);
end

function checkAbort(cfg)
[pressed, firstPress] = KbQueueCheck(cfg.kbDev);
if pressed && firstPress(cfg.keys.escape) > 0
    error('Experiment terminated by user (ESC).');
end
end

function holdForSecondsWithAbort(tEnd, cfg)
while GetSecs < tEnd
    checkAbort(cfg);
    WaitSecs(0.001);
end
end

function [key, secs] = waitForKeyQueue(validKeys, escapeKey, maxSecs, cfg)
KbQueueFlush(cfg.kbDev);
tStart = GetSecs;
while true
    [pressed, firstPress] = KbQueueCheck(cfg.kbDev);
    if pressed
        if firstPress(escapeKey) > 0
            error('Experiment terminated by user (ESC).');
        end
        vkPress = firstPress(validKeys);
        idx = find(vkPress > 0);
        if ~isempty(idx)
            [secs, minIdx] = min(vkPress(idx));
            key = validKeys(idx(minIdx));
            return;
        end
    end
    if (GetSecs - tStart) > maxSecs
        key = NaN;
        secs = GetSecs;
        return;
    end
    WaitSecs(0.001);
end
end

function [missedFramesTotal, missedEventsTotal] = addMissedFlips(missedFramesTotal, missedEventsTotal, targetTime, actualTime, ifi)
lateSec = actualTime - targetTime;
lateFrames = floor((lateSec / ifi) + 0.5);
if lateFrames > 0
    missedFramesTotal = missedFramesTotal + lateFrames;
    missedEventsTotal = missedEventsTotal + 1;
end
end

function tex = makeGratingTexture(window, sz, cyclesPerStim, contrast, bg, gaborSigmaFrac)
if nargin < 6 || isempty(gaborSigmaFrac)
    gaborSigmaFrac = 0.40;
end
[x, y] = meshgrid(linspace(-1, 1, sz), linspace(-1, 1, sz));
radius = sqrt(x.^2 + y.^2);
carrier = cos(2 * pi * cyclesPerStim * x);
sigma = max(1, gaborSigmaFrac);
envelope = exp(-(radius.^2) / (2 * sigma^2));
img = bg + (contrast * 0.5) * (envelope .* carrier);
img = min(max(img, 0), 1);
alpha = min(max(envelope, 0), 1);
rgb = uint8(img * 255);
a = uint8(alpha * 255);
rgba = cat(3, rgb, rgb, rgb, a);
tex = Screen('MakeTexture', window, rgba);
end

function drawGratings(window, tex, allRects, orientations, bg)
Screen('FillRect', window, bg);
for i = 1:4
    Screen('DrawTexture', window, tex, [], allRects(i,:), orientations(i));
end
end

function drawFixation(window, fixationCoords, lineWidthPx, colour, xCentre, yCentre)
Screen('DrawLines', window, fixationCoords, lineWidthPx, colour, [xCentre yCentre], 2);
end

function drawFixationOnly(window, bg, fixationCoords, lineWidthPx, colour, xCentre, yCentre)
Screen('FillRect', window, bg);
drawFixation(window, fixationCoords, lineWidthPx, colour, xCentre, yCentre);
end

function cleanup(window, cfg)
try
    try ListenChar(0); catch, end
    try Priority(0); catch, end
    try KbQueueRelease(cfg.kbDev); catch, end
    try ShowCursor; catch, end
    try Screen('Close', 'all'); catch, end
    if ~isempty(window)
        try Screen('CloseAll'); catch, end
    end
catch
    try Screen('CloseAll'); catch, end
end
end
